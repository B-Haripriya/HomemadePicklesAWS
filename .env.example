# ─────────────────────────────────────────────────────────────────────────────
# HomeMade Pickles & Snacks — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-32-char-string
FLASK_ENV=development
FLASK_DEBUG=True

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# 1. Go to https://cloud.mongodb.com → your cluster → Connect → Drivers
# 2. Copy the connection string and replace <username>, <password>, and <cluster>
MONGO_URI=mongodb+srv://pickles:pickles123@cluster0.nawo8hm.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGO_DB_NAME=pickles

# ── CloudWatch (optional — leave as False for local dev) ──────────────────────
ENABLE_CLOUDWATCH=False
CLOUDWATCH_LOG_GROUP=/pickles-app/flask
CLOUDWATCH_STREAM_NAME=app-stream
AWS_REGION=us-east-1
